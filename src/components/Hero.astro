---
interface Props {
  class?: string;
}
---
<section class="relative h-screen w-full flex items-center justify-center overflow-hidden bg-black" aria-labelledby="hero-title">
  <div class="absolute inset-0 z-0">
    <div
      class="parallax-img w-full h-full bg-cover bg-center opacity-60 transition-transform duration-[15000ms] ease-out scale-110"
      id="hero-img"
      style="background-image: url('/assets/hero-bg.webp')"
      aria-hidden="true"
    ></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/40"></div>
  </div>

  <div class="relative z-10 text-center px-4 mask-reveal">
    <span class="inline-block font-ui-label text-white/70 uppercase tracking-[0.4em] text-[10px] mb-6">Tradizione Italiana</span>
    <h1 id="hero-title" class="font-display-lg text-white tracking-tight leading-none blur-reveal">
      Desde 1987<br /><span class="italic font-normal">criando memórias.</span>
    </h1>
    <div class="mt-12 blur-reveal" style="transition-delay: 300ms">
      <a
        class="group flex items-center gap-4 mx-auto text-white hover:opacity-80 transition-opacity focus-visible-ring"
        href="#historia"
      >
        <span class="w-12 h-[1px] bg-white/30 group-hover:w-20 transition-all duration-500"></span>
        <span class="font-ui-label uppercase tracking-widest text-xs">Descubra Nossa Jornada</span>
      </a>
    </div>
  </div>

  <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-4 text-white/30 mask-reveal" style="transition-delay: 600ms">
    <span class="text-[10px] uppercase tracking-widest vertical-text">Scroll</span>
    <div class="w-[1px] h-12 bg-gradient-to-b from-white/30 to-transparent"></div>
  </div>
</section>

<script is:inline>
  // Parallax effect on hero image
  const heroImg = document.getElementById('hero-img');
  if (heroImg) {
    window.addEventListener('scroll', () => {
      const scrolled = window.pageYOffset;
      const rate = scrolled * -0.3;
      heroImg.style.transform = `translateY(${rate}px) scale(1.1)`;
    }, { passive: true });
  }
</script>