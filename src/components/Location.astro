---
interface Props {}
---
<section class="py-stack-xl px-margin-desktop max-w-container-max mx-auto" id="localizacao" aria-labelledby="location-title">
  <div class="bg-white rounded-2xl shadow-elevated overflow-hidden border border-tertiary/10 flex flex-col md:flex-row mask-reveal active">
    <div class="w-full md:w-2/5 p-stack-xl flex flex-col justify-center">
      <h2 id="location-title" class="font-headline-md text-headline-md text-on-background mb-stack-lg">Venha nos visitar</h2>
      <div class="space-y-stack-md mb-stack-xl">
        <div class="flex items-start gap-4">
          <span class="material-symbols-outlined text-primary mt-1">location_on</span>
          <div>
            <p class="font-ui-label text-ui-label text-on-background">Endereço</p>
            <p class="font-body-md text-on-surface-variant">Rua das Flores, 1987, Centro - São Paulo/SP</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="material-symbols-outlined text-primary mt-1">schedule</span>
          <div>
            <p class="font-ui-label text-ui-label text-on-background">Horário</p>
            <p class="font-body-md text-on-surface-variant">Segunda a Domingo: 10h às 22h</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="material-symbols-outlined text-primary mt-1">call</span>
          <div>
            <p class="font-ui-label text-ui-label text-on-background">Telefone</p>
            <p class="font-body-md text-on-surface-variant">(11) 4567-8901</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="material-symbols-outlined text-primary mt-1">email</span>
          <div>
            <p class="font-ui-label text-ui-label text-on-background">E-mail</p>
            <p class="font-body-md text-on-surface-variant">contato@dinapoli.com.br</p>
          </div>
        </div>
      </div>
      <a
        href="https://maps.google.com/?q=Rua+das+Flores+1987+Centro+S%C3%A3o+Paulo+SP"
        target="_blank"
        rel="noopener"
        class="w-full bg-primary-container text-on-primary-container py-4 rounded-lg font-ui-label text-ui-label flex items-center justify-center gap-2 hover:opacity-90 transition-opacity focus-visible-ring"
      >
        <span class="material-symbols-outlined">directions</span>
        Como chegar
      </a>
    </div>
    <div class="w-full md:w-3/5 min-h-[400px] bg-surface-dim overflow-hidden grayscale contrast-125 opacity-80 relative">
      <iframe
        class="w-full h-full border-0"
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3656.123!2d-46.633!3d-23.550!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjPCsDMzJzAwLjMiUyA0NsKwMzcnNTQuNFdW!5e0!3m2!1spt-BR!2sbr!4v1234567890!5m2!1spt-BR!2sbr"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Localização Di Napoli no Google Maps"
      ></iframe>
    </div>
  </div>
</section>