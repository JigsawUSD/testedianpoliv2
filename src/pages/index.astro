---
import { siteConfig, seo, jsonLd } from '../data/site.ts';
import Preloader from '../components/Preloader.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import Timeline from '../components/Timeline.astro';
import ProductGrid from '../components/ProductGrid.astro';
import Experience from '../components/Experience.astro';
import Reviews from '../components/Reviews.astro';
import Location from '../components/Location.astro';
import Footer from '../components/Footer.astro';
import RevealObserver from '../components/RevealObserver.astro';
import { products, reviews } from '../data/site.ts';
---

<!doctype html>
<html lang="pt-BR" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{seo.home.title}</title>
    <meta name="description" content={seo.home.description} />
    <meta name="keywords" content={seo.home.keywords} />
    <link rel="canonical" href={seo.home.canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={seo.home.canonical} />
    <meta property="og:title" content={seo.home.title} />
    <meta property="og:description" content={seo.home.description} />
    <meta property="og:image" content={siteConfig.ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={siteConfig.locale} />
    <meta property="og:site_name" content={siteConfig.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={siteConfig.twitterHandle} />
    <meta name="twitter:url" content={seo.home.canonical} />
    <meta name="twitter:title" content={seo.home.title} />
    <meta name="twitter:description" content={seo.home.description} />
    <meta name="twitter:image" content={siteConfig.ogImage} />

    <!-- Theme & PWA -->
    <meta name="theme-color" content={siteConfig.themeColor} />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />

    <!-- Preload critical fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" /></noscript>

    <!-- Material Symbols -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=search,arrow_back,arrow_forward,east,location_on,schedule,call,email,directions,star,arrow_back,arrow_forward" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=search,arrow_back,arrow_forward,east,location_on,schedule,call,email,directions,star,arrow_back,arrow_forward" media="print" onload="this.media='all'" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd.localBusiness)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd.breadcrumb)}></script>

    <!-- Critical CSS inline (will be inlined by Astro) -->
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <script src="../main.js"></script>
  <body class="h-full bg-background font-body antialiased">
    <Preloader />

    <Header scrollY={0} />

    <main id="main-content" class="relative">
      <Hero />
      <Manifesto />
      <Timeline />
      <ProductGrid products={products} />
      <Experience />
      <Reviews reviews={reviews} />
      <Location />
    </main>

    <Footer />

    <RevealObserver />

    <script is:inline>
      // Lenis Smooth Scroll
      import('lenis').then(({ default: Lenis }) => {
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smooth: true,
          smoothTouch: false,
          touchMultiplier: 2,
          infinite: false,
          lerp: 0.08
        });

        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        // Header scroll effect
        const header = document.getElementById('main-header');
        if (header) {
          lenis.on('scroll', ({ scroll }: { scroll: number }) => {
            if (scroll > 50) {
              header.classList.add('bg-white/80', 'backdrop-blur-md', 'py-stack-sm', 'shadow-sm');
              header.classList.remove('py-stack-md');
            } else {
              header.classList.remove('bg-white/80', 'backdrop-blur-md', 'py-stack-sm', 'shadow-sm');
              header.classList.add('py-stack-md');
            }
          });
        }
      }).catch(console.error);

      // Smooth scroll for anchor links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
          const targetId = this.getAttribute('href');
          if (targetId === '#') return;
          const target = document.querySelector(targetId);
          if (target) {
            e.preventDefault();
            import('lenis').then(({ default: Lenis }) => {
              // Lenis will handle smooth scroll automatically
              window.location.hash = targetId;
            });
          }
        });
      });

      // IntersectionObserver fallback for reduced motion
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.querySelectorAll('.mask-reveal, .blur-reveal').forEach(el => {
          el.classList.add('active');
        });
      }
    </script>
  </body>
</html>
